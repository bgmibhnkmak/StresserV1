# Required: Telegram Bot Token (from @BotFather)
# =============================================================================
TELEGRAM_BOT_TOKEN=7384442199:AAHpSGClKmiadXhVz4DGUzTRb0pDu6wJ898

# =============================================================================
# Required: API Access Token for the stresser service
# =============================================================================
API_ACCESS_TOKEN=c8505cb96e903374df0e18f65761d664ab81d5e9919bc54e9868fe3e69a3ebe8

# =============================================================================
# Optional: Authorized Telegram User IDs (comma-separated)
# Leave empty to allow all users (not recommended)
# =============================================================================
AUTHORIZED_USERS=7265678519

# =============================================================================
# Optional: Extra passphrase authentication layer
# If set, users must run /auth <passphrase> before using /attack
# =============================================================================
ACCESS_PASSPHRASE=your_secure_passphrase_here

# =============================================================================
# Optional: Restrict bot to specific Telegram chats/groups
# Comma-separated chat IDs (use negative values for groups)
# =============================================================================
ALLOWED_CHAT_IDS=

# =============================================================================
# Optional: Proxy Configuration
# Only use proxies YOU control. Never use public/untrusted proxies.
# Format: protocol://user:pass@host:port (comma-separated)
# =============================================================================
PROXY_ENABLED=false
PROXY_LIST=

# =============================================================================
# Optional: SSL/TLS Configuration
# =============================================================================
SSL_VERIFY=true
SSL_CERT_FILE=

# =============================================================================
# Optional: Logging Configuration
# =============================================================================
LOGS_DIR=attack_logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
